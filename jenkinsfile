pipeline {
    agent any
    stages {
        stage('Descargar') {
            steps {
                git branch: 'main', url: 'https://github.com/emanuelcarrillo15/Organizacion_Archivos.git'
            }
        }
        stage('Apagar') {
            steps {
                // Probamos con la ruta completa o el alias de docker
                sh 'docker compose down || docker-compose down'
            }
        }
        stage('Encender') {
            steps {
                sh 'docker compose up -d || docker-compose up -d'
            }
        }
        stage('Verificar') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
